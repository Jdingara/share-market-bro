# Copy this file to .env and fill in your real values. Never commit .env itself.

KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# Your Zerodha login credentials, used only for the automated daily login flow.
KITE_USER_ID=your_zerodha_client_id
KITE_PASSWORD=your_zerodha_password

# Base32 TOTP secret from enabling 2FA (TOTP) on your Zerodha account.
# This is shown once when you set up TOTP in Kite web/app settings - save it then.
KITE_TOTP_SECRET=your_totp_secret_here
